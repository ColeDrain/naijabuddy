# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Virtual Environment
.venv/
venv/
ENV/
env/

# Database files (local SQLite)
*.db
*.db-journal
*.db-shm
*.db-wal

# Large model files & weights — too big for git, but keep the directory itself
# (via models/.gitkeep) so the Dockerfile's `COPY models` works on a fresh clone.
models/*
!models/.gitkeep

# Articles and retrieved PDFs
articles/
/articles/

# Bruno Local API collection (ignored as requested by the user)
bruno/
/bruno/

# OS-specific files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Scratch / throwaway experiment workspace
scratch/

# LLM evaluation artifact cache
eval_artifacts/

# Log files
*.log

# Large regenerable data — n=2,000 dense datasets are rebuilt by
# `python local_data_prep.py`; the cross-domain Amazon Books+Movies CSVs
# are pulled by `hf download McAuley-Lab/Amazon-Reviews-2023 ...`. Committing
# them adds ~1.6 GB to git history forever and the docs already declare them
# regenerable (see numbers_integrity.md).
# data/*_dense.csv and data/item_embeddings.npz are now tracked via Git
# LFS (see .gitattributes), not ignored. This means the HF Spaces build
# can COPY data /app/data and find them directly — no regeneration at
# build time (which OOM'd or took 30+ min on HF's CPU-only build env).
data/amazon_crossdomain/

# Binary files HF Hub rejects outside of Xet/LFS — keep PDFs out of the
# tracked tree. (The competition brief PDF is publicly available via the
# hackathon's website; no need to vendor a copy here.)
*.pdf

# Exception: the compiled solution-paper PDFs are submission artefacts and
# *must* be committed. They are well under HF's 10 MiB regular-Git limit
# (~150-220 KB each), so they don't need LFS/Xet. Generated by
# `pandoc + pdflatex` from solution_paper*.md with the latex-document
# skill's academic-paper preamble (mathptmx Times + helvet + microtype +
# booktabs + Unicode declarations) — see scripts/build_pdfs.sh.
!papers_pdf/
!papers_pdf/*.pdf
