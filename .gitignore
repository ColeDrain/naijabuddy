# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Virtual Environment
.venv/
venv/
ENV/
env/

# Database files (local SQLite)
*.db
*.db-journal
*.db-shm
*.db-wal

# Large model files & weights — too big for git, but keep the directory itself
# (via models/.gitkeep) so the Dockerfile's `COPY models` works on a fresh clone.
models/*
!models/.gitkeep

# Articles and retrieved PDFs
articles/
/articles/

# Bruno Local API collection (ignored as requested by the user)
bruno/
/bruno/

# OS-specific files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Scratch / throwaway experiment workspace
scratch/

# LLM evaluation artifact cache
eval_artifacts/

# Log files
*.log
