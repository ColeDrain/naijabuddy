# =====================================================================
# NAIJABUDDY DOCKER IGNORE CONFIGURATION
# Best-practice MLOps container footprint optimization
# =====================================================================

# Version Control
.git
.gitignore

# Python caching & environments
__pycache__/
*.pyc
*.pyo
*.pyd
.venv/
env/
venv/
ENV/
.pytest_cache/
.ipynb_checkpoints/

# Operating System garbage
.DS_Store
Thumbs.db

# Incomplete Hugging Face scratch caches. The finalized model weights — the
# .gguf and the embedding-model snapshots — ARE sent in the build context so
# the build copies them in instead of re-downloading ~2.2 GB.
models/.cache/
models/hf_home/xet/

# Local SQLite database — the build re-seeds it inside data_enricher.py
naijabuddy.db
naijabuddy.db-shm
naijabuddy.db-wal

# Scratch workspace, eval artifact cache, logs — not needed in the image
scratch/
eval_artifacts/
*.log

# Development / Scratch scripts (keeps image footprint lightweight)
verify_api.py
verify_concept.py
articles/
BCT Hack Brief.pdf
arxiv_results.json
